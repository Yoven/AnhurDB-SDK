# AnhurDB Claude-memory plugin — configuration.
# Copy the relevant vars into your shell environment (or a gitignored .env you source).
# The API key lives ONLY in the environment — it is sent as the X-API-Key header by the
# hook scripts and is NEVER written to the transcript, logs, or stdout.
#
# Use a PER-TENANT key (one key per tenant), NOT the master key. This is the same key the
# AnhurDB MCP tools accept.

# Required: the tenant API key this agent's memory lives under.
ANHUR_API_KEY=anhur_xxx_replace_with_your_tenant_key

# Your AnhurDB HTTP endpoint. The default below is for a local AnhurDB.
ANHUR_URL=http://localhost:8000

# Your memory profile WITHIN the tenant the API key selects. Recall reads STRICTLY from this profile,
# so one stable name = one accumulating memory. CHOOSE IT ONCE: changing it later makes recall stop
# surfacing what was saved under the old name (nothing is lost — it's still there under the old name —
# it just isn't re-surfaced). Keep it stable across sessions.
ANHUR_CONTAINER=claude-ltm

# NOTE: saving turns is only half of it. Distilling fact/decision/emotion/etc. from them is done by
# AnhurDB's Smart Units (its cognitive layer). If they aren't enabled on your AnhurDB, turns are
# still saved but no typed memories are derived. See README → "Structured memory (Smart Units)".

# ── Optional tuning ──────────────────────────────────────────────────────────
# ANHUR_RECALL_LIMIT=8                       # max items per section injected at session start
# ANHUR_HTTP_TIMEOUT=15                      # seconds per HTTP call
#
# ANHUR_MAX_CHUNK_CHARS=24000               # SIZE of each persisted chunk. A long delta is
#                                           # split into N chunks of this size and ALL of them
#                                           # are persisted (queued on failure) — nothing is
#                                           # truncated/dropped (no-silent-loss). Bigger means
#                                           # fewer/larger records (mind the per-memory size cap and
#                                           # the Smart Unit processing load).
#
# ANHUR_INCLUDE_TOOLS=calls                 # how tool blocks are persisted:
#                                           #   none  = conversation text only
#                                           #   calls = text + a COMPACT tool_use line (default)
#                                           #   all   = the above + a TRUNCATED tool_result
#                                           # (thinking blocks are never persisted)
#
# ANHUR_STATE_DIR=$HOME/.anhur-claude-memory # queue + cursors + log live here (never committed)
#
# ANHUR_ARCHIVE=true                        # LOSSLESS verbatim transcript archive (thinking + tools +
#                                           # everything, byte-for-byte), default ON. Set to "false"
#                                           # to disable. This is the complete counterpart to the
#                                           # filtered episodic feed — nothing is ever dropped.
# ANHUR_ARCHIVE_DIR=$HOME/.anhur-claude-memory/archive  # where the archive lives (point at NFS if you want)

# Overrides the AnhurDB MCP server URL that .mcp.json connects to (the bundled MCP tools). Default is
# http://localhost:8090/mcp; point it at your hosted MCP endpoint if you use one. Read by Claude Code
# when expanding .mcp.json — NOT by the hook binary. NOTE: this ${VAR} expansion works in the Claude
# Code CLI but NOT the macOS Desktop app (there, edit .mcp.json to a hardcoded URL).
# ANHUR_MCP_URL=http://localhost:8090/mcp
