# AnhurDB Claude-memory plugin — configuration.
# Copy the relevant vars into your shell environment (or a gitignored .env you source).
# The API key lives ONLY in the environment — it is sent as the X-API-Key header by the
# hook scripts and is NEVER written to the transcript, logs, or stdout.
#
# Use a PER-TENANT key (one key per tenant), NOT the master key. This is the same key the
# AnhurDB MCP tools accept.

# Required: the tenant API key this agent's memory lives under.
ANHUR_API_KEY=anhur_xxx_replace_with_your_tenant_key

# AnhurDB HTTP endpoint (Traefik/router). Default below matches the local docker-compose stack.
ANHUR_URL=http://localhost:8000

# The "memory profile" container this agent reads/writes. One stable tag = one accumulating
# profile that get_profile() can aggregate. Keep it stable across sessions.
ANHUR_CONTAINER=claude-ltm

# ── Optional tuning ──────────────────────────────────────────────────────────
# ANHUR_RECALL_LIMIT=8                       # max items per section injected at session start
# ANHUR_HTTP_TIMEOUT=15                      # seconds per HTTP call
#
# ANHUR_MAX_CHUNK_CHARS=24000               # SIZE of each persisted chunk. A long delta is
#                                           # split into N chunks of this size and ALL of them
#                                           # are persisted (queued on failure) — nothing is
#                                           # truncated/dropped (no-silent-loss). Bigger means
#                                           # fewer/larger records (mind the 1MB /ingest cap and
#                                           # the extraction-pipeline load).
#
# ANHUR_INCLUDE_TOOLS=calls                 # how tool blocks are persisted:
#                                           #   none  = conversation text only
#                                           #   calls = text + a COMPACT tool_use line (default)
#                                           #   all   = the above + a TRUNCATED tool_result
#                                           # (thinking blocks are never persisted)
#
# ANHUR_STATE_DIR=$HOME/.anhur-claude-memory # queue + cursors + log live here (never committed)

# Only needed if you let THIS plugin register the MCP server (.mcp.json). Points at anhur-mcp.
# ANHUR_MCP_URL=http://localhost:8090/sse
