{
  "name": "anhurdb",
  "version": "1.0.0",
  "description": "TypeScript SDK for AnhurDB — dead-simple memory for AI agents",
  "author": "AnhurDB",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test dist/test/test/memory.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "anhurdb",
    "memory",
    "ai",
    "agents",
    "cognitive",
    "vector",
    "database",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anhurdb/anhurdb-sdk"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.4.0"
  }
}
